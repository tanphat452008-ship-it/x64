<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@id/main_speed"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:visibility="visible">

    <com.triggertrap.seekarc.SeekArc
        android:id="@id/speed_line"
        :touchInside="true"
        android:layout_width="@dimen/_150sdp"
        android:layout_height="@dimen/_80sdp"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="4.0dip"
        android:padding="@dimen/_7sdp"
        app:arcColor="#ffc4c4c4"
        app:arcWidth="@dimen/_2sdp"
        app:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:max="240"
        app:progress="220"
        app:progressColor="#ff01a3ff"
        app:progressWidth="@dimen/_2sdp"
        app:rotation="180"
        app:startAngle="60"
        app:sweepAngle="240" />

    <TextView
        android:id="@id/speed_text"
        android:layout_width="@dimen/_50sdp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:gravity="center"
        android:text="574"
        android:textColor="#ffffffff"
        android:textSize="@dimen/_20sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.398" />

    <TextView
        android:id="@id/speed_milleage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="000000"
        android:textColor="@android:color/white"
        android:textSize="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.173" />

    <ImageView
        android:id="@id/imageView"
        android:layout_width="@dimen/_13sdp"
        android:layout_height="@dimen/_13sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.197"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/ic_hpcar" />

    <ImageView
        android:id="@id/imageView2"
        android:layout_width="@dimen/_13sdp"
        android:layout_height="@dimen/_13sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.802"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="1.0"
        app:srcCompat="@drawable/ic_fuel" />

    <com.triggertrap.seekarc.SeekArc
        android:id="@id/speed_fuel"
        android:layout_width="@dimen/_85sdp"
        android:layout_height="@dimen/_85sdp"
        android:layout_toRightOf="@id/speed_fuel"
        android:padding="@dimen/_5sdp"
        android:rotationY="180.0"
        app:arcColor="#ffc4c4c4"
        app:arcWidth="@dimen/_2sdp"
        app:enabled="false"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.584"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="1.0"
        app:progress="90"
        app:progressColor="#ff01a3ff"
        app:progressWidth="@dimen/_2sdp"
        app:rotation="200"
        app:startAngle="38"
        app:sweepAngle="80"
        app:touchInside="true" />

    <com.triggertrap.seekarc.SeekArc
        android:id="@id/speed_hp"
        android:layout_width="@dimen/_85sdp"
        android:layout_height="@dimen/_85sdp"
        android:layout_toRightOf="@id/speed_fuel"
        android:padding="@dimen/_5sdp"
        app:arcColor="#ffc4c4c4"
        app:arcWidth="@dimen/_2sdp"
        app:enabled="false"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.405"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="1.0"
        app:progress="90"
        app:progressColor="#ff01a3ff"
        app:progressWidth="@dimen/_2sdp"
        app:rotation="200"
        app:startAngle="38"
        app:sweepAngle="80"
        app:touchInside="true" />

    <ImageView
        android:id="@id/speed_engine"
        android:layout_width="@dimen/_10sdp"
        android:layout_height="@dimen/_10sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.392"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.914"
        app:srcCompat="@drawable/ic_engine_off" />

    <ImageView
        android:id="@id/speed_doors"
        android:layout_width="@dimen/_10sdp"
        android:layout_height="@dimen/_10sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.914"
        app:srcCompat="@drawable/ic_doors_lock" />

    <ImageView
        android:id="@id/speed_lights"
        android:layout_width="@dimen/_10sdp"
        android:layout_height="@dimen/_10sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.607"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.914"
        app:srcCompat="@drawable/ic_lights_off" />

    <TextView
        android:id="@id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="0%"
        android:textColor="#ffffffff"
        android:textSize="@dimen/_5sdp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.191"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.814" />

    <TextView
        android:id="@+id/percent_carhp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="100%"
        android:textColor="#ffffffff"
        android:textSize="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.266"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="0%"
        android:textColor="#ffffffff"
        android:textSize="@dimen/_5sdp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.81"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.821" />

    <TextView
        android:id="@+id/percent_fuel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_bold"
        android:text="100%"
        android:textColor="#ffffffff"
        android:textSize="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="@id/speed_line"
        app:layout_constraintEnd_toEndOf="@id/speed_line"
        app:layout_constraintHorizontal_bias="0.718"
        app:layout_constraintStart_toStartOf="@id/speed_line"
        app:layout_constraintTop_toTopOf="@id/speed_line"
        app:layout_constraintVertical_bias="0.0" />
</androidx.constraintlayout.widget.ConstraintLayout>