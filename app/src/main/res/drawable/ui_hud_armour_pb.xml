<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#24ffffff"/>
            <corners android:radius="@dimen/_9sdp"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient android:startColor="#6880ff" android:endColor="#233489" android:angle="0"/>
                <corners android:radius="@dimen/_9sdp"/>
            </shape>
        </clip>
    </item>
</layer-list>
